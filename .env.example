# ═══════════════════════════════════════════════════════════════════════════════
# FRUITOPIA CONFIGURATION  —  copy this file to .env and fill in your values
#
# IMPORTANT: Never commit .env to Git (it's in .gitignore).
#
# ── WHERE TO PUT THESE VARIABLES PER PLATFORM ─────────────────────────────────
#   Vercel  → Project Settings → Environment Variables
#   Render  → Dashboard → your service → Environment
#   cPanel  → Node.js App → Environment variables (or a .env OUTSIDE public_html)
#   Netlify → Netlify serves STATIC files only. It does NOT run /api.
#             Put payment/email/SMS vars on your BACKEND host (Render/cPanel/VPS)
#             and set NODE_API_URL on Netlify pointing to that backend.
#
# ── NAMING CONVENTIONS ────────────────────────────────────────────────────────
#   FIREBASE_API_KEY=...        ← server-side name
#   VITE_FIREBASE_API_KEY=...   ← frontend name (REQUIRED for Netlify/Vercel
#                                 static builds so values bake into the bundle)
# Leave any gateway you don't use blank — it's simply skipped.
# *_SANDBOX=true → test mode; set to false to go live.
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
# FIREBASE  (REQUIRED unless you use Supabase)
# Firebase Console → Project Settings → General → Your apps
# ───────────────────────────────────────────────────────────────────────────────
# IMPORTANT: keep these EMPTY ("") for a fresh install. Empty quoted values let
# the app boot into the Install Wizard, and the wizard writes the real values
# straight into these lines. If you paste fake placeholder text here instead,
# the app will think it's already configured and SKIP the wizard (broken site).
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_DATABASE_ID="(default)"


# ───────────────────────────────────────────────────────────────────────────────
# SUPABASE  (OPTIONAL — alternative backend to Firebase)
# Use the public anon / publishable key only. Never put admin passwords here.
# Keep EMPTY ("") for a fresh install — the Install Wizard fills these in.
# ───────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
# Server-side secret — REQUIRED for automatic payments (the server writes the
# paid order on the gateway callback/webhook). Supabase → Settings → API →
# service_role secret. Keep it PRIVATE — never expose it in the browser / VITE_.
SUPABASE_SERVICE_ROLE_KEY=""


# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENT GATEWAYS  (all OPTIONAL — fill in only the ones you use)
# These are read SERVER-SIDE. On Netlify put them on your backend host, not Netlify.
# ═══════════════════════════════════════════════════════════════════════════════

# ── bKash (Bangladesh) ────────────────────────────────────────────────────────
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_SANDBOX=true

# ── Nagad (Bangladesh) ────────────────────────────────────────────────────────
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_BASE_URL=https://api.mynagad.com/api/dfs
NAGAD_CALLBACK_URL=
NAGAD_SANDBOX=true

# ── SSLCommerz (Bangladesh) ───────────────────────────────────────────────────
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWORD=
SSLCZ_SANDBOX=true

# ── Razorpay (India) ──────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_SANDBOX=false

# ── UPI (India — direct intent link) ──────────────────────────────────────────
UPI_VPA=
UPI_PAYEE_NAME=Store

# ── Paytm (India) ─────────────────────────────────────────────────────────────
PAYTM_MID=
PAYTM_MERCHANT_KEY=
PAYTM_SANDBOX=true

# ── Stripe (Global) ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SANDBOX=true

# ── PayPal (Global) ───────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SANDBOX=true

# ── JazzCash (Pakistan) ───────────────────────────────────────────────────────
JAZZCASH_MID=
JAZZCASH_PASSWORD=
JAZZCASH_HASH_KEY=
JAZZCASH_SALT=
JAZZCASH_SANDBOX=true

# ── Easypaisa (Pakistan) ──────────────────────────────────────────────────────
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_SANDBOX=true

# ── PayFast (South Africa) ────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true


# ───────────────────────────────────────────────────────────────────────────────
# EMAIL  (OPTIONAL — order/notification emails via SMTP)
# Recommended: Gmail + App Password (myaccount.google.com/apppasswords)
# ───────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Fruitopia


# ───────────────────────────────────────────────────────────────────────────────
# SMS  (OPTIONAL — Twilio)
# ───────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890


# ───────────────────────────────────────────────────────────────────────────────
# reCAPTCHA  (OPTIONAL — server-side verification)
# Secret Key stays here on the server. The Site Key goes in Admin Panel → CMS.
# ───────────────────────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=


# ───────────────────────────────────────────────────────────────────────────────
# PLATFORM & SERVER
# ───────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3005
VITE_APP_URL=http://localhost:3005

# Comma-separated list of allowed CORS origins for the Node server (Render/cPanel/VPS).
# Example: https://yourstore.com,https://www.yourstore.com
ALLOWED_ORIGINS=

# NETLIFY ONLY: URL of your backend Node server that actually runs /api/*.
# Required on Netlify deploys — set it to your Render/cPanel/VPS URL.
# Example: https://your-app.onrender.com
NODE_API_URL=
